#!/bin/bash
# Pre-push hook for claude-octopus
# Runs comprehensive validation before pushing

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Auto-sync marketplace.json with actual counts
if [[ -x "$ROOT_DIR/scripts/sync-marketplace.sh" ]]; then
    "$ROOT_DIR/scripts/sync-marketplace.sh"
    # Abort push if marketplace.json is out of sync — user must commit the update
    if ! git -C "$ROOT_DIR" diff --quiet .claude-plugin/marketplace.json 2>/dev/null; then
        git -C "$ROOT_DIR" add .claude-plugin/marketplace.json
        echo "ERROR: marketplace.json was updated with correct counts."
        echo "Please commit the staged change and push again."
        exit 1
    fi
fi

# Run the full validation script if it exists
if [[ -x "$ROOT_DIR/scripts/validate-release.sh" ]]; then
    "$ROOT_DIR/scripts/validate-release.sh"
else
    # Fallback to basic checks
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    NC='\033[0m'

    echo -e "${GREEN}🐙 Claude Octopus Pre-Push Check${NC}"

    PLUGIN_VERSION=$(grep '"version"' .claude-plugin/plugin.json | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/')
    README_VERSION=$(grep -o 'Version-[0-9.]*' README.md | head -1 | sed 's/Version-//')

    if [[ "$PLUGIN_VERSION" != "$README_VERSION" ]]; then
        echo -e "${RED}ERROR: Version mismatch detected${NC}"
        echo "  plugin.json: v$PLUGIN_VERSION"
        echo "  README.md:   v$README_VERSION"
        exit 1
    fi

    if git rev-parse "v$PLUGIN_VERSION" >/dev/null 2>&1; then
        echo -e "${GREEN}✓ Tag v$PLUGIN_VERSION exists${NC}"
    else
        echo -e "${YELLOW}NOTE: Tag v$PLUGIN_VERSION not yet created${NC}"
        echo "  Create with: git tag -a v$PLUGIN_VERSION -m 'Release v$PLUGIN_VERSION'"
    fi

    echo -e "${GREEN}✓ Version check passed (v$PLUGIN_VERSION)${NC}"
fi
exit 0
